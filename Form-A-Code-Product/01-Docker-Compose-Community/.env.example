# ═══════════════════════════════════════════════════════════════
# Form-A 社区分发版 · 环境变量配置模板
# ═══════════════════════════════════════════════════════════════
# 使用方法：
#   1. cp .env.example .env
#   2. 修改以下所有 "changeme" 密码
#   3. docker compose up -d
# ═══════════════════════════════════════════════════════════════

# ──────────── PostgreSQL ────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app
POSTGRES_HOST=postgres

# ──────────── n8n 工作流引擎 ────────────
N8N_ENCRYPTION_KEY=changeme
N8N_USER_MANAGEMENT_DISABLED=false
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_METRICS=false

# ──────────── 授权服务 (auth-server) ────────────
# 社区版留空即可；企业版填写正式 License Key
AUTH_LICENSE_KEY=
AUTH_ADMIN_PASSWORD=changeme
AUTH_JWT_SECRET=changeme
AUTH_JWT_EXPIRES_IN=24h

# ──────────── AI-API 安全审核代理 (ai-gateway) ────────────
AI_GATEWAY_API_KEY=changeme
AI_GATEWAY_RATE_LIMIT=100
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
AUDIT_ENABLED=true
AUTH_SERVICE_API_KEY=changeme

# ──────────── Redis ────────────
REDIS_PASSWORD=changeme

# ──────────── Nginx ────────────
NGINX_SSL_ENABLED=false
DOMAIN=localhost

# ──────────── pgAdmin ────────────
PGADMIN_DEFAULT_EMAIL=admin@form-a.local
PGADMIN_DEFAULT_PASSWORD=changeme

# ──────────── 通用 ────────────
LOG_LEVEL=info
